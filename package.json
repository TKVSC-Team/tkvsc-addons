{
  "name": "tkvsc-addons-root",
  "version": "1.0.0",
  "private": true,
  "description": "Root for TKVSC add-on extensions",
  "workspaces": [
    "botw-support",
    "splatoon3-support",
    "tkmm-cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "watch": "npm run watch --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "package": "npm run package --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}