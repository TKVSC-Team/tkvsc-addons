{
  "name": "tkvsc-example-addon",
  "displayName": "TKVSC Example Addon",
  "description": "Starter template for TKVSC companion extensions — copy this folder when building a new addon.",
  "version": "0.0.1",
  "publisher": "TKVSC-Team",
  "license": "MIT",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "TKVSC-Team.totk-vscode"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tkvsc-example.showProjectInfo",
        "title": "TKVSC Example: Show Project Info",
        "category": "TKVSC Example"
      },
      {
        "command": "tkvsc-example.logApiStatus",
        "title": "TKVSC Example: Log API Status",
        "category": "TKVSC Example"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "tkvsc-example.showProjectInfo",
          "when": "view == totk-editor.archives && viewItem == archiveRoot",
          "group": "9_tkvscExample@1"
        }
      ],
      "commandPalette": [
        {
          "command": "tkvsc-example.showProjectInfo",
          "when": "false"
        },
        {
          "command": "tkvsc-example.logApiStatus"
        }
      ]
    },
    "configuration": {
      "title": "TKVSC Example Addon",
      "properties": {
        "tkvscExample.enableVerboseLogging": {
          "type": "boolean",
          "default": false,
          "description": "Log extra detail to the TKVSC Example output channel when the API becomes ready."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext .ts",
    "package": "tsc --noEmit && node esbuild.js",
    "package:vsix": "npm run package && node -e \"require('fs').mkdirSync('out', { recursive: true }); require('child_process').execSync('npx vsce package --allow-missing-repository --out out/tkvsc-example-addon-' + process.env.npm_package_version + '.vsix', { stdio: 'inherit', cwd: process.cwd() })\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
